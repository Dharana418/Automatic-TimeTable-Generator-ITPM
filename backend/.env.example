# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=your_jwt_secret_here
ADMIN_SETUP_KEY=your_admin_setup_key_here

# CORS – comma-separated list of allowed origins for staging/production
# Example: CORS_ORIGINS=https://app.example.com,https://staging.example.com
# Leave empty (or omit) to allow localhost only (development default)
CORS_ORIGINS=

# Supabase (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
